{
  "name": "Warranty-Warriors",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@langchain/core": "^1.1",
    "@langchain/langgraph": "^1.2.9",
    "@sap-ai-sdk/langchain": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "db": {
        "[test]": {
          "kind": "sqlite",
          "credentials": {
            "url": ":memory:"
          },
          "data": [
            "test/data"
          ]
        }
      },
      "DATASPHERE": {
        "kind": "rest",
        "credentials": {
          "destination": "mh-bdc-dsp-dev-warranty"
        }
      },
      "destinations": true
    }
  }
}
